# StrongClaw 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Keys
# 最后更新：2026-03-04

# ============================================
# 模型提供商 API Keys
# ============================================
# 选择一个或多个提供商，至少需要一个

# Anthropic Claude（最强推理能力，2026 最新）
# 获取地址: https://console.anthropic.com/
# 最新模型: claude-opus-4.6, claude-sonnet-4.6, claude-haiku-4.5
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini（免费额度大，推荐新手，2026 最新）
# 获取地址: https://ai.google.dev/
# 最新模型: gemini-3.1-pro-preview, gemini-3-flash-preview
# GOOGLE_API_KEY=xxxxx

# Moonshot Kimi（长上下文，2026 最新）
# 获取地址: https://platform.moonshot.cn/
# 最新模型: kimi-k2.5, kimi-k2-thinking
# MOONSHOT_API_KEY=xxxxx

# DeepSeek（国内速度快，价格低，推荐，2026 最新）
# 获取地址: https://platform.deepseek.com/
# 最新模型: deepseek-r1, deepseek-v3.2-exp, deepseek-coder
# DEEPSEEK_API_KEY=xxxxx

# Alibaba Qwen（中文理解好，2026 最新）
# 获取地址: https://dashscope.aliyun.com/
# 最新模型: qwen3.5-max, qwen3.5-plus, qwen3.5-turbo
# QWEN_API_KEY=xxxxx

# OpenRouter（一个 Key 访问所有模型，推荐）
# 获取地址: https://openrouter.ai/
# 支持所有主流模型
# OPENROUTER_API_KEY=sk-or-xxxxx

# Together AI（开源模型）
# 获取地址: https://www.together.ai/
# 最新模型: meta-llama/Llama-3.3-70B-Instruct-Turbo
# TOGETHER_API_KEY=xxxxx

# ============================================
# 默认配置（可选）
# ============================================

# 默认使用的模型（如果不指定，会自动检测）
# DEFAULT_MODEL=gemini-3-flash-preview

# 默认使用的提供商（如果不指定，会自动检测）
# DEFAULT_PROVIDER=google

# 是否启用详细日志
# VERBOSE=false

# ============================================
# 推荐配置（2026 最新）
# ============================================

# 新手推荐：
# GOOGLE_API_KEY=your-key
# DEFAULT_MODEL=gemini-3-flash-preview

# 国内用户推荐：
# DEEPSEEK_API_KEY=your-key
# DEFAULT_MODEL=deepseek-r1

# 追求性能推荐：
# ANTHROPIC_API_KEY=your-key
# DEFAULT_MODEL=claude-opus-4.6

# 代码任务推荐：
# DEEPSEEK_API_KEY=your-key
# DEFAULT_MODEL=deepseek-coder

# 多模型使用推荐：
# OPENROUTER_API_KEY=your-key
# DEFAULT_MODEL=google/gemini-3-flash-preview
